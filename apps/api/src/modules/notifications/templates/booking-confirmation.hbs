<!DOCTYPE html>
<html>
<body style="font-family:sans-serif;color:#1a1a1a;max-width:600px;margin:0 auto;padding:32px">
  <h1 style="font-size:22px;font-weight:600">Booking Confirmed</h1>
  <p>Hi {{firstName}}, your appointment has been confirmed.</p>
  <table style="width:100%;border-collapse:collapse;margin-top:24px">
    <tr><td style="padding:8px 0;color:#666">Service</td>  <td style="padding:8px 0;font-weight:500">{{serviceName}}</td></tr>
    <tr><td style="padding:8px 0;color:#666">Date</td>     <td style="padding:8px 0;font-weight:500">{{scheduledAt}}</td></tr>
    <tr><td style="padding:8px 0;color:#666">Duration</td> <td style="padding:8px 0;font-weight:500">{{duration}} min</td></tr>
    <tr><td style="padding:8px 0;color:#666">Total</td>    <td style="padding:8px 0;font-weight:500">{{currency}} {{totalPrice}}</td></tr>
  </table>
  <p style="margin-top:32px;font-size:13px;color:#888">Rivique Beauty — reply to this email if you need to make changes.</p>
</body>
</html>
